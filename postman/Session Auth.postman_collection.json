{
  "info": {
    "_postman_id": "8ae3fd90-c647-4cbb-b019-3fb1eca1e81e",
    "name": "Session Auth",
    "description": "This collection provides a complete set of API requests to test a session-based authentication system. It covers user registration, login, session management, and protected user operations such as fetching and updating profile data. The collection is designed to validate authentication flows, ensure secure session handling, and demonstrate how authorized access is enforced within a Node.js and PostgreSQL backend in a local development environment.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Create User",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"{{USER-NAME}}\",\n  \"email\": \"{{USER-EMAIL}}\",\n  \"password\": \"{{USER_PASSWORD}}\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{BASE_URL}}/users/signup",
          "host": ["{{BASE_URL}}"],
          "path": ["users", "signup"]
        },
        "description": "Creates a new user account by accepting name, email, and password. This endpoint is used to register new users in the system."
      }
    },
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{USER-EMAIL}}\",\n  \"password\": \"{{USER_PASSWORD}}\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{BASE_URL}}/users/login",
          "host": ["{{BASE_URL}}"],
          "path": ["users", "login"]
        },
        "description": "Authenticates a user by verifying their email and password. On success, a session ID is returned, which is required for accessing protected routes."
      }
    },
    {
      "name": "Get Authenticated User",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "session-id",
            "value": "{{SESSION-ID}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{BASE_URL}}/users",
          "host": ["{{BASE_URL}}"],
          "path": ["users"]
        },
        "description": "Retrieves the currently authenticated user's details using a valid session ID. This endpoint verifies session validity and demonstrates access to protected routes."
      }
    },
    {
      "name": "Update User Profile",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "session-id",
            "value": "{{SESSION-ID}}",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"{{USER-NAME}}\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{BASE_URL}}/users",
          "host": ["{{BASE_URL}}"],
          "path": ["users"]
        },
        "description": "Updates the authenticated user's profile information. Requires a valid session ID to authorize the request."
      }
    }
  ],
  "variable": [
    {
      "key": "BASE_URL",
      "value": "http://localhost:8000"
    },
    {
      "key": "USER-EMAIL",
      "value": ""
    },
    {
      "key": "USER_PASSWORD",
      "value": ""
    },
    {
      "key": "USER-NAME",
      "value": ""
    },
    {
      "key": "SESSION-ID",
      "value": ""
    }
  ]
}
